# ======================================================
# BornToShare Wizard UI — .dockerignore
# ======================================================

# ------------------------------------------------------
# Git / VCS
# ------------------------------------------------------
.git
.gitignore
.github/

# ------------------------------------------------------
# Python cache
# ------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ------------------------------------------------------
# Environment / Secrets
# ------------------------------------------------------
.env
*.env
*.secret
*.key
*.pem
*.crt
*.pfx

# ------------------------------------------------------
# Runtime / State
# ------------------------------------------------------
data/
runtime/
state/
logs/
tmp/
var/

wizard_state.json
wizard_runtime.json

# ------------------------------------------------------
# Database / Dumps
# ------------------------------------------------------
*.sql.gz
*.dump
*.bak
*.db
*.sqlite

# ------------------------------------------------------
# Local compose overrides
# ------------------------------------------------------
docker-compose.override.yml
podman-compose.override.yml

# ------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------
.vscode/
.idea/
*.iml

# ------------------------------------------------------
# OS
# ------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------
# Tests / Coverage
# ------------------------------------------------------
.coverage
htmlcov/
pytest_cache/

# ------------------------------------------------------
# Frontend artifacts (if generated outside Docker)
# ------------------------------------------------------
dist/
build/

# ------------------------------------------------------
# Documentation artifacts
# ------------------------------------------------------
*.pdf
*.md.bak
