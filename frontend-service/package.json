{
  "name": "borntoshare-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",

  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js dev",
    "build": "LC_ALL=C LANG=C node ./node_modules/vite/bin/vite.js build --logLevel error",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test:auth-snapshot": "npx tsx ./src/lib/server/auth/principal-cookie.test.ts && npx tsx ./src/hooks.server.test.ts",
    "test:identity-sources-mapper": "npx tsx ./src/lib/services/mappers/identity-sources.mapper.test.ts",
    "test:principal-search": "npx tsx ./src/lib/utils/principal-search.test.ts",
    "test:request-approval-errors": "npx tsx ./src/lib/utils/request-approval-errors.test.ts",
    "test:entity-operational-mapper": "npx tsx ./src/lib/services/mappers/entity-operational.mapper.test.ts",
    "test:storage-roots-overview-mapper": "npx tsx ./src/lib/services/mappers/storage-roots-overview.mapper.test.ts",
    "test:storage-root-governance": "npx tsx ./src/lib/utils/storage-root-governance.test.ts",
    "test:storage-root-alerts": "npx tsx ./src/lib/services/mappers/storage-root-alerts.mapper.test.ts",
    "test:storage-root-detail-mapper": "npx tsx ./src/lib/services/mappers/storage-root-detail.mapper.test.ts",
    "test:storage-endpoint-provisioning-mapper": "npx tsx ./src/lib/services/mappers/storage-endpoint-provisioning.mapper.test.ts",
    "test:visual-state-mapper": "npx tsx ./src/lib/services/mappers/visual-state.mapper.test.ts",
    "test:delete-guard": "npx tsx ./src/lib/utils/delete-guard.test.ts"
  },

  "dependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.49.0",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "vite": "^6.4.1"
  },

  "devDependencies": {
    "svelte-preprocess": "^6.0.0"
  },

  "overrides": {
    "cookie": "0.7.2"
  }
}
